    private void showDeviceManager() {
        LinearLayout root = page("设备管理", "查看绑定设备、公钥指纹、风险标记和会话状态");
        TextView output = box("点击刷新设备列表");
        Button refresh = primary("刷新设备列表");
        root.addView(refresh, full(dp(10)));
        root.addView(output, full(dp(16)));
        refresh.setOnClickListener(v -> api.get("/v1/admin/devices?limit=100", result -> {
            if (redirectUnauthorized(result)) return;
            output.setText(result.success ? pretty(result.data) : result.message);
        }));

        EditText deviceId = input("设备记录 ID", false);
        root.addView(deviceId, full(dp(10)));
        LinearLayout row = horizontal();
        Button detail = small("设备详情");
        Button revoke = small("撤销设备");
        row.addView(detail, weight());
        row.addView(revoke, weightMargins());
        root.addView(row, full(dp(14)));
        detail.setOnClickListener(v -> {
            String id = deviceId.getText().toString().trim();
            if (id.isEmpty()) { output.setText("请输入设备记录 ID"); return; }
            api.get("/v1/admin/devices/detail?id=" + encode(id), result -> {
                if (redirectUnauthorized(result)) return;
                output.setText(result.success ? pretty(result.data) : result.message);
            });
        });
        revoke.setOnClickListener(v -> confirmDanger("撤销设备", "该设备当前会话将立即失效。", () -> {
            String id = deviceId.getText().toString().trim();
            if (id.isEmpty()) { output.setText("请输入设备记录 ID"); return; }
            api.post("/v1/admin/devices/revoke", new JSONObject().put("id", id), result -> {
                if (redirectUnauthorized(result)) return;
                output.setText(result.success ? pretty(result.data) : result.message);
            });
        }));

        EditText license = input("卡密或卡密 ID，用于撤销该卡全部设备", false);
        root.addView(license, full(dp(10)));
        Button revokeAll = danger("撤销该卡全部设备");
        revokeAll.setOnClickListener(v -> confirmDanger("撤销全部设备", "该卡密所有当前设备都会立即退出。", () -> {
            String value = license.getText().toString().trim();
            if (value.isEmpty()) { output.setText("请输入卡密或卡密 ID"); return; }
            api.post("/v1/admin/devices/revoke-all", identifier(value), result -> {
                if (redirectUnauthorized(result)) return;
                output.setText(result.success ? pretty(result.data) : result.message);
            });
        }));
        root.addView(revokeAll, full(dp(16)));
        addBack(root);
        setContentView(wrap(root));
    }

    private void showVersionSettings() {
        showLoading("版本与更新");
        api.get("/v1/admin/settings", result -> {
            if (redirectUnauthorized(result)) return;
            if (!result.success) { showErrorPage("版本与更新", result.message); return; }
            currentSettings = result.data.optJSONObject("settings");
            if (currentSettings == null) currentSettings = new JSONObject();
            renderVersionSettings();
        });
    }

    private void renderVersionSettings() {
        LinearLayout root = page("版本与更新", "保存后由 Worker 动态下发，无需重新编译客户端");
        EditText minimum = numeric("最低允许 versionCode");
        EditText latest = numeric("最新 versionCode");
        CheckBox force = check("低于最新版本时强制更新", currentSettings.optBoolean("forceUpdate", false));
        EditText url = input("HTTPS 更新下载地址", false);
        EditText message = multiline("更新说明");
        minimum.setText(String.valueOf(currentSettings.optInt("minAppVersion", 5)));
        latest.setText(String.valueOf(currentSettings.optInt("latestAppVersion", 8)));
        url.setText(currentSettings.optString("updateUrl", ""));
        message.setText(currentSettings.optString("updateMessage", ""));
        root.addView(minimum, full(dp(8)));
        root.addView(latest, full(dp(8)));
        root.addView(force, full(dp(8)));
        root.addView(url, full(dp(8)));
        root.addView(message, full(dp(12)));
        TextView result = status("");
        Button save = primary("保存版本配置");
        save.setOnClickListener(v -> {
            JSONObject changes = new JSONObject()
                    .put("minAppVersion", parseLong(minimum, 5L))
                    .put("latestAppVersion", parseLong(latest, 8L))
                    .put("forceUpdate", force.isChecked())
                    .put("updateUrl", url.getText().toString().trim())
                    .put("updateMessage", message.getText().toString().trim());
            saveSettings(changes, "version-update", result, this::showVersionSettings);
        });
        root.addView(save, full(dp(8)));
        root.addView(result, full(dp(12)));
        addBack(root);
        setContentView(wrap(root));
    }

    private void showSecuritySettings() {
        showLoading("安全策略");
        api.get("/v1/admin/settings", result -> {
            if (redirectUnauthorized(result)) return;
            if (!result.success) { showErrorPage("安全策略", result.message); return; }
            currentSettings = result.data.optJSONObject("settings");
            if (currentSettings == null) currentSettings = new JSONObject();
            renderSecuritySettings();
        });
    }

    private void renderSecuritySettings() {
        LinearLayout root = page("安全策略", "所有输入均有服务器安全范围限制");
        EditText session = numeric("客户端会话秒数 900-86400");
        EditText adminSession = numeric("管理会话秒数 900-86400");
        EditText recheck = numeric("前台复检秒数 300-43200");
        EditText offline = numeric("新版离线秒数 0-86400");
        EditText legacyOffline = numeric("旧版离线秒数 0-172800");
        EditText lease = numeric("脚本租期秒数 300-86400");
        EditText challenge = numeric("nonce 秒数 30-300");
        EditText risk = numeric("风险强制在线阈值 1-5");
        CheckBox globalOnline = check("全局强制在线", currentSettings.optBoolean("globalForceOnline", false));
        CheckBox selfUnbind = check("允许用户自助更换设备", currentSettings.optBoolean("selfUnbindEnabled", true));
        EditText penalty = numeric("解绑扣除秒数 0-259200");
        EditText cooldown = numeric("解绑冷却秒数 0-2592000");
        EditText window = numeric("统计窗口秒数 86400-7776000");
        EditText limit = numeric("窗口内最多解绑次数 1-30");

        setNumber(session, "sessionSeconds", 7200);
        setNumber(adminSession, "adminSessionSeconds", 43200);
        setNumber(recheck, "foregroundRecheckSeconds", 1800);
        setNumber(offline, "offlineGraceSeconds", 21600);
        setNumber(legacyOffline, "legacyOfflineGraceSeconds", 86400);
        setNumber(lease, "scriptLeaseSeconds", 21600);
        setNumber(challenge, "challengeSeconds", 90);
        setNumber(risk, "riskForceOnlineThreshold", 2);
        setNumber(penalty, "unbindPenaltySeconds", 21600);
        setNumber(cooldown, "unbindCooldownSeconds", 86400);
        setNumber(window, "unbindWindowSeconds", 2592000);
        setNumber(limit, "unbindWindowLimit", 5);

        EditText[] fields = {session, adminSession, recheck, offline, legacyOffline, lease,
                challenge, risk, penalty, cooldown, window, limit};
        for (EditText field : fields) root.addView(field, full(dp(8)));
        root.addView(globalOnline, full(dp(8)));
        root.addView(selfUnbind, full(dp(12)));
        TextView result = status("");
        Button save = primary("保存安全策略");
        save.setOnClickListener(v -> {
            JSONObject changes = new JSONObject()
                    .put("sessionSeconds", parseLong(session, 7200L))
                    .put("adminSessionSeconds", parseLong(adminSession, 43200L))
                    .put("foregroundRecheckSeconds", parseLong(recheck, 1800L))
                    .put("offlineGraceSeconds", parseLong(offline, 21600L))
                    .put("legacyOfflineGraceSeconds", parseLong(legacyOffline, 86400L))
                    .put("scriptLeaseSeconds", parseLong(lease, 21600L))
                    .put("challengeSeconds", parseLong(challenge, 90L))
                    .put("riskForceOnlineThreshold", parseLong(risk, 2L))
                    .put("globalForceOnline", globalOnline.isChecked())
                    .put("selfUnbindEnabled", selfUnbind.isChecked())
                    .put("unbindPenaltySeconds", parseLong(penalty, 21600L))
                    .put("unbindCooldownSeconds", parseLong(cooldown, 86400L))
                    .put("unbindWindowSeconds", parseLong(window, 2592000L))
                    .put("unbindWindowLimit", parseLong(limit, 5L));
            saveSettings(changes, "security-policy", result, this::showSecuritySettings);
        });
        root.addView(save, full(dp(8)));
        root.addView(result, full(dp(12)));
        addBack(root);
        setContentView(wrap(root));
    }
