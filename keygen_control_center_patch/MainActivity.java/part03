        }));
        EditText historyId = input("历史记录 ID", false);
        Button rollback = danger("回滚到该历史配置");
        root.addView(historyId, full(dp(8)));
        root.addView(rollback, full(dp(14)));
        rollback.setOnClickListener(v -> confirmDanger("回滚系统配置",
