async function activeDeviceCount(env, licenseId) {
  const row = await env.DB.prepare("SELECT COUNT(*) AS count FROM devices WHERE license_id=? AND revoked_at IS NULL").bind(licenseId).first();
  return Number(row?.count || 0);
