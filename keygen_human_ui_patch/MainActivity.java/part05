        Button select = secondary("应用资源版本");
        root.addView(select, full(dp(8)));
        select.setOnClickListener(v -> confirmDanger("切换远程资源版本",
                "切换后新启动的客户端会使用所选版本。请先确认该版本已经登记并验证。",
                () -> api.post("/v1/admin/runtime/select",
                        new J().put("version", version.getText().toString().trim()), result -> {
                            if (redirectUnauthorized(result)) return;
                            output.setText(result.success ? HumanFormat.operation(result.data) : result.message);
                        })));

        Button diagnostics = secondary("查看最近一次技术诊断");
        diagnostics.setOnClickListener(v -> showDiagnostics("远程资源技术诊断", lastData[0]));
        root.addView(diagnostics, full(dp(14)));
        addBack(root);
        setContentView(wrap(root));
    }

