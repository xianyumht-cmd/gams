    private void showSettingsHistory() {
        LinearLayout root = page("配置历史", "每次保存前都会自动保留旧配置，便于恢复");
        addHelp(root, "列表会显示配置版本、修改时间、修改原因和主要设置。需要恢复时复制“历史记录编号”。");
        TextView output = box("点击刷新读取最近配置历史。");
        Button refresh = primary("刷新配置历史");
        root.addView(refresh, full(dp(10)));
        root.addView(output, full(dp(12)));

        final JSONObject[] lastData = {new J()};
        refresh.setOnClickListener(v -> api.get("/v1/admin/settings/history?limit=50", result -> {
            if (redirectUnauthorized(result)) return;
            if (result.success) {
                lastData[0] = result.data;
                output.setText(HumanFormat.history(result.data));
            } else output.setText(result.message);
        }));

        EditText historyId = input("粘贴历史记录编号", false);
        addLabeledField(root, "要恢复的历史记录", "恢复后仍会保留现在的配置记录，可以再次回滚。", historyId);
        Button rollback = danger("恢复到这份历史配置");
        root.addView(rollback, full(dp(10)));
        rollback.setOnClickListener(v -> confirmDanger("恢复历史配置",
                "当前设置会被历史快照替换。现有会话代数会保留，不会让已经撤销的旧登录重新生效。",
                () -> {
                    String id = historyId.getText().toString().trim();
                    if (id.isEmpty()) {
                        output.setText("请先填写历史记录编号。");
                        return;
                    }
                    api.post("/v1/admin/settings/rollback", new J().put("historyId", id), result -> {
                        if (redirectUnauthorized(result)) return;
                        output.setText(result.success ? "配置已恢复，新的配置版本已生成。" : result.message);
                    });
                }));

        Button diagnostics = secondary("查看最近一次技术诊断");
        diagnostics.setOnClickListener(v -> showDiagnostics("配置历史技术诊断", lastData[0]));
        root.addView(diagnostics, full(dp(14)));
        addBack(root);
        setContentView(wrap(root));
    }

    private void saveSettings(JSONObject changes, String reason, TextView result, Runnable afterSuccess) {
        int version = currentSettings.optInt("configVersion", 0);
        J body = new J()
                .put("settings", changes)
                .put("expectedVersion", version)
                .put("reason", reason);
        api.post("/v1/admin/settings/update", body, response -> {
            if (redirectUnauthorized(response)) return;
            result.setText(response.success ? "保存成功，服务器已开始使用新设置。" : response.message);
            if (response.success && afterSuccess != null) afterSuccess.run();
        });
    }

