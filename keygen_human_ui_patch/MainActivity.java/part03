            int newMin = (int) parseLong(minimum, oldMin);
            int newLatest = (int) parseLong(latest, oldLatest);
            String updateUrl = url.getText().toString().trim();
            if (newMin < 1 || newLatest < 1) {
                result.setText("版本数字必须大于0。");
                return;
            }
            if (newMin > newLatest) {
                result.setText("最低允许版本不能高于当前最新版本。");
                return;
            }
            if (!updateUrl.isEmpty() && !updateUrl.toLowerCase(Locale.ROOT).startsWith("https://")) {
                result.setText("下载地址必须以 https:// 开头。");
                return;
            }
            if (force.isChecked() && updateUrl.isEmpty()) {
                result.setText("开启强制更新前必须填写安装包下载地址。");
                return;
            }

            String impact = "最低允许版本：" + oldMin + " → " + newMin +
                    "\n当前最新版本：" + oldLatest + " → " + newLatest +
                    "\n强制更新：" + yesNo(currentSettings.optBoolean("forceUpdate", false)) +
                    " → " + yesNo(force.isChecked());
            if (newMin > oldMin) {
                impact += "\n\n注意：版本 " + oldMin + " 到 " + (newMin - 1) + " 的客户端将无法继续使用。";
            }

            J changes = new J()
                    .put("minAppVersion", newMin)
                    .put("latestAppVersion", newLatest)
                    .put("forceUpdate", force.isChecked())
                    .put("updateUrl", updateUrl)
                    .put("updateMessage", message.getText().toString().trim());
            confirmChange("确认版本设置", impact,
                    () -> saveSettings(changes, "version-update", result, this::showVersionSettings));
        });
        root.addView(save, full(dp(8)));
        root.addView(result, full(dp(12)));

        Button diagnostics = secondary("查看当前系统状态");
        diagnostics.setOnClickListener(v -> showSettingsStatus());
        root.addView(diagnostics, full(dp(12)));
        addBack(root);
        setContentView(wrap(root));
    }

    private void showSecuritySettings() {
        showLoading("安全策略");
        api.get("/v1/admin/settings", result -> {
            if (redirectUnauthorized(result)) return;
            if (!result.success) {
                showErrorPage("安全策略", result.message);
                return;
            }
            currentSettings = result.data.optJSONObject("settings");
            if (currentSettings == null) currentSettings = new J();
            renderSecuritySettings();
        });
    }

