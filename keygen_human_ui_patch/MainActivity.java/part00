        addHelp(root, "搜索可以填写卡密预览、备注或记录编号。列表中的“记录编号”可用于单卡和批量操作。");

        EditText query = input("搜索卡密或备注，可留空查看全部", false);
        TextView output = box("点击“查询卡密”读取服务器列表。");
        Button search = primary("查询卡密");
        root.addView(query, full(dp(10)));
        root.addView(search, full(dp(12)));
        root.addView(output, full(dp(12)));
