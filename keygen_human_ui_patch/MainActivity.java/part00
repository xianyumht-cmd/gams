            search.setEnabled(false);
            String path = "/v1/admin/licenses?limit=100&q=" + encode(query.getText().toString());
            api.get(path, result -> {
                search.setEnabled(true);
                if (redirectUnauthorized(result)) return;
                output.setText(result.success ? HumanFormat.licenses(result.data) : result.message);
            });
        });

        Button create = secondary("创建新卡密");
        create.setOnClickListener(v -> showCreateLicenseDialog(output));
        root.addView(create, full(dp(20)));

        root.addView(section("单张卡密操作"), full(dp(8)));
        addHelp(root, "可以填写完整卡密，也可以粘贴查询结果中的记录编号。");
        EditText keyOrId = input("完整卡密或记录编号", false);
        root.addView(keyOrId, full(dp(10)));

        Button detail = secondary("查看卡密和设备详情");
        detail.setOnClickListener(v -> {
            String value = keyOrId.getText().toString().trim();
            if (value.isEmpty()) {
                output.setText("请先输入完整卡密或记录编号。");
                return;
            }
            api.get(detailPath(value), result -> {
                if (redirectUnauthorized(result)) return;
                output.setText(result.success ? HumanFormat.licenseDetail(result.data) : result.message);
            });
        });
        root.addView(detail, full(dp(10)));

        LinearLayout row = horizontal();
        Button disable = small("停用");
        Button enable = small("启用");
